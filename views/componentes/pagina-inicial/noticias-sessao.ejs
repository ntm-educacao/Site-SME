<!-- News Section -->
<section id="news" class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-10">
            <div>
                <h3 id="news-section-title" class="font-heading text-3xl font-bold text-slate-800">
                    <i class="fas fa-newspaper mr-3"></i>Últimas Notícias
                </h3>
                <p class="text-slate-500 mt-2">Fique por dentro das novidades da educação municipal</p>
            </div>
            <a href="/noticias"
                class="text-blue-600 hover:text-blue-700 font-semibold flex items-center gap-2 transition-colors">
                Ver todas <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        <% if (noticias && noticias.length > 0) { %>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% noticias.forEach(function(noticia) { %>
            <a href="<%= noticia.link %>" target="_blank" rel="noopener noreferrer" class="block news-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all cursor-pointer">
                <% if (noticia.img) { %>
                <img src="<%= noticia.img %>" alt="<%= noticia.titulo %>"
                    class="w-full h-48 object-cover" loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 items-center justify-center hidden">
                    <i class="fas fa-newspaper text-6xl text-white"></i>
                </div>
                <% } else { %>
                <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                    <i class="fas fa-newspaper text-6xl text-white"></i>
                </div>
                <% } %>
                <div class="p-6">
                    <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-medium">
                            <i class="fas fa-tag mr-1"></i><%= noticia.categoria %>
                        </span>
                        <% if (noticia.data) { %>
                        <span>•</span>
                        <span><i class="fas fa-calendar mr-1"></i><%= noticia.data %></span>
                        <% } %>
                    </div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-3 line-clamp-2">
                        <%= noticia.titulo %>
                    </h4>
                    <% if (noticia.descricao) { %>
                    <p class="text-slate-600 text-sm line-clamp-3"><%= noticia.descricao %></p>
                    <% } %>
                </div>
            </a>
            <% }) %>
        </div>
        <% } else { %>
        <p class="text-slate-500 text-center py-8">Não foi possível carregar as notícias no momento.</p>
        <% } %>
    </div>
</section>
