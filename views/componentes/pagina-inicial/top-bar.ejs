<div id="top-bar" class="bg-blue-500 text-white text-xs py-1.5">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-end items-center gap-x-1 text-right">
        <nav aria-label="Acessibilidade" class="flex items-center gap-1">
            <span class="text-white/60 text-xs pr-1 hidden sm:inline">Acessibilidade:</span>

            <button onclick="diminuirFonte()"
                    title="Diminuir tamanho da fonte"
                    aria-label="Diminuir tamanho da fonte"
                    class="topbar-a11y-btn">
                <span aria-hidden="true" class="font-bold" style="font-size:0.7rem;">A</span><span aria-hidden="true" class="font-bold" style="font-size:0.55rem; vertical-align:super;">-</span>
            </button>

            <button onclick="aumentarFonte()"
                    title="Aumentar tamanho da fonte"
                    aria-label="Aumentar tamanho da fonte"
                    class="topbar-a11y-btn">
                <span aria-hidden="true" class="font-bold" style="font-size:0.85rem;">A</span><span aria-hidden="true" class="font-bold" style="font-size:0.6rem; vertical-align:super;">+</span>
            </button>

            <span class="text-white/30 px-0.5" aria-hidden="true">|</span>

            <button onclick="toggleAltoContraste()"
                    id="btn-alto-contraste"
                    title="Alto contraste"
                    aria-label="Alternar alto contraste"
                    aria-pressed="false"
                    class="topbar-a11y-btn gap-1">
                <i class="fas fa-circle-half-stroke text-xs" aria-hidden="true"></i>
                <span>Alto Contraste</span>
            </button>
        </nav>
    </div>
</div>