<!doctype html>
<html lang="pt-BR" class="h-full">

<head>
    <%- include("../head") %>
    <title>Notícias - SME Mossoró</title>
</head>

<body class="h-full bg-slate-50">
    <div id="app" class="w-full h-full overflow-x-hidden overflow-y-auto">
        <%- include("../componentes/pagina-inicial/top-bar") %>

        <header id="main-header" class="bg-blue-800 shadow-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 bg-blue-800">
                <div class="flex items-center justify-between py-4 bg-blue-800">
                    <%- include("../componentes/pagina-inicial/header-principal/logo") %>
                    <nav class="hidden lg:flex items-center gap-1" id="main-nav">
                        <%- include("../componentes/pagina-inicial/header-principal/botao-inicio") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-institucional") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-ensino") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-unidades") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-servicos") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-NTM") %>
                        <%- include("../componentes/pagina-inicial/header-principal/nav-item-sistemas") %>
                    </nav>
                    <%- include("../componentes/pagina-inicial/header-principal/mobile-menu-button") %>
                </div>
            </div>
            <%- include("../componentes/pagina-inicial/mobile-menu") %>
        </header>

        <section class="bg-blue-800 py-12">
            <div class="max-w-7xl mx-auto px-4 text-center">
                <h1 class="font-heading text-4xl font-bold text-white mb-3">
                    <i class="fas fa-newspaper mr-3"></i>Notícias
                </h1>
                <p class="text-blue-200 text-lg">Fique por dentro das últimas notícias da educação municipal de Mossoró</p>
            </div>
        </section>

        <section class="py-16">
            <div class="max-w-7xl mx-auto px-4">
                <% if (noticias && noticias.length > 0) { %>
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% noticias.forEach(function(noticia) { %>
                    <a href="<%= noticia.link %>" target="_blank" rel="noopener noreferrer" class="block news-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all cursor-pointer">
                        <% if (noticia.img) { %>
                        <img src="<%= noticia.img %>" alt="<%= noticia.titulo %>"
                            class="w-full h-48 object-cover" loading="lazy"
                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 items-center justify-center hidden">
                            <i class="fas fa-newspaper text-6xl text-white"></i>
                        </div>
                        <% } else { %>
                        <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                            <i class="fas fa-newspaper text-6xl text-white"></i>
                        </div>
                        <% } %>
                        <div class="p-6">
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                                <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-medium">
                                    <i class="fas fa-tag mr-1"></i><%= noticia.categoria %>
                                </span>
                                <% if (noticia.data) { %>
                                <span>•</span>
                                <span><i class="fas fa-calendar mr-1"></i><%= noticia.data %></span>
                                <% } %>
                            </div>
                            <h2 class="font-heading font-bold text-lg text-slate-800 mb-3 line-clamp-2">
                                <%= noticia.titulo %>
                            </h2>
                            <% if (noticia.descricao) { %>
                            <p class="text-slate-600 text-sm line-clamp-3"><%= noticia.descricao %></p>
                            <% } %>
                        </div>
                    </a>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="text-center py-20">
                    <i class="fas fa-newspaper text-6xl text-slate-300 mb-4"></i>
                    <p class="text-slate-500 text-lg">Não foi possível carregar as notícias no momento.</p>
                    <p class="text-slate-400 text-sm mt-2">Tente novamente mais tarde.</p>
                </div>
                <% } %>
            </div>
        </section>

        <%- include("../componentes/pagina-inicial/footer") %>
    </div>
    <script src="/scripts/pagina-inicial/scripts.js"></script>
</body>

</html>
