<!doctype html>
<html lang="pt-BR" class="h-full">

<head>
    <%- include("../../head") %>
    <title>Nossa Equipe - NTM | Secretaria Municipal de Educação</title>
</head>

<body class="h-full bg-slate-50">
    <div id="app" class="w-full h-full overflow-x-hidden overflow-y-auto">
        <%- include("../../componentes/pagina-inicial/top-bar") %>

        <header id="main-header" class="bg-blue-800 shadow-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 bg-blue-800">
                <div class="flex items-center justify-between py-4 bg-blue-800">
                    <%- include("../../componentes/pagina-inicial/header-principal/logo") %>
                    <nav class="hidden lg:flex items-center gap-1" id="main-nav">
                        <%- include("../../componentes/pagina-inicial/header-principal/botao-inicio") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-institucional") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-ensino") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-unidades") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-servicos") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-NTM") %>
                        <%- include("../../componentes/pagina-inicial/header-principal/nav-item-sistemas") %>
                    </nav>
                    <%- include("../../componentes/pagina-inicial/header-principal/mobile-menu-button") %>
                </div>
            </div>
            <%- include("../../componentes/pagina-inicial/mobile-menu") %>
        </header>

        <section class="bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 text-white py-16">
            <div class="max-w-7xl mx-auto px-4">
                <div class="flex items-center gap-4 mb-4">
                    <a href="/" class="text-blue-200 hover:text-white text-sm transition-colors flex items-center gap-1">
                        <i class="fas fa-house"></i> Início
                    </a>
                    <i class="fas fa-chevron-right text-blue-300 text-xs"></i>
                    <span class="text-blue-200 text-sm">NTM</span>
                    <i class="fas fa-chevron-right text-blue-300 text-xs"></i>
                    <span class="text-white text-sm font-medium">Nossa Equipe</span>
                </div>
                <div class="flex items-center gap-5">
                    <div class="w-16 h-16 rounded-2xl overflow-hidden flex-shrink-0">
                        <img src="/img/NTM/NTM-logo.jpeg" alt="Logo NTM" class="w-full h-full object-contain">
                    </div>
                    <div>
                        <h1 class="text-3xl lg:text-4xl font-heading font-bold leading-tight">
                            Nossa Equipe
                        </h1>
                        <p class="text-blue-200 mt-2 text-lg">Conheça a equipe que faz a diferença!</p>
                    </div>
                </div>
            </div>
        </section>

        <main class="max-w-7xl mx-auto px-4 py-12">
             <section class="mb-12">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                        <i class="fas fa-users-gear text-blue-700"></i>
                    </div>
                    <h2 class="text-2xl font-heading font-bold text-slate-800">Nossa Equipe</h2>
                </div>
                <div class="mb-6 rounded-2xl overflow-hidden shadow-sm border border-slate-100">
                    <img src="/img/NTM/ntm-equipe.jpg" alt="Equipe NTM" class="w-full max-h-[480px] object-cover object-center">
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
                    <p class="text-slate-600 leading-relaxed text-base mb-8">
                        O NTM conta, atualmente, com uma equipe de profissionais capacitados:
                    </p>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <div class="text-center p-5 bg-blue-100 rounded-xl">
                            <div class="w-12 h-12 bg-blue-700 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-user-tie text-white text-lg"></i>
                            </div>
                            <div class="text-2xl font-heading font-bold text-blue-800">01</div>
                            <div class="text-sm text-slate-600 mt-1 font-medium">Coordenador</div>
                        </div>
                        <div class="text-center p-5 bg-green-100 rounded-xl">
                            <div class="w-12 h-12 bg-green-700 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-chalkboard-user text-white text-lg"></i>
                            </div>
                            <div class="text-2xl font-heading font-bold text-green-800">03</div>
                            <div class="text-sm text-slate-600 mt-1 font-medium">Professores Formadores</div>
                        </div>
                        <div class="text-center p-5 bg-purple-100 rounded-xl">
                            <div class="w-12 h-12 bg-purple-700 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-screwdriver-wrench text-white text-lg"></i>
                            </div>
                            <div class="text-2xl font-heading font-bold text-purple-800">03</div>
                            <div class="text-sm text-slate-600 mt-1 font-medium">Técnicos</div>
                        </div>
                        <div class="text-center p-5 bg-amber-100 rounded-xl">
                            <div class="w-12 h-12 bg-amber-600 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-broom text-white text-lg"></i>
                            </div>
                            <div class="text-2xl font-heading font-bold text-amber-700">03</div>
                            <div class="text-sm text-slate-600 mt-1 font-medium">Estagiários</div>
                        </div>
                    </div>
                </div>
            </section>

            <section>
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                        <i class="fas fa-users-gear text-blue-700"></i>
                    </div>
                    <h2 class="text-2xl font-heading font-bold text-slate-800">Equipe pedagógica</h2>
                </div>
                <div class="mb-6 rounded-2xl overflow-hidden shadow-sm border border-slate-100">
                    <img src="/img/NTM/equipe_pedagogica.jpg" alt="Equipe Pedagógica" class="w-full max-h-[630px] object-cover object-center">
                </div>
                <p class="text-slate-600 leading-relaxed text-base mb-8 text-justify">
                        A equipe pedagógica é formada por Frank Werlly, Cristhiane Marques, Socorro Souza e Stênio Lucio. A Equipe Pedagógica promove formações continuadas, oficinas e cursos que auxiliam os educadores a compreender e utilizar recursos tecnológicos de maneira crítica e criativa em sala de aula. Essas ações formativas incentivam o uso de metodologias ativas, ferramentas digitais, recursos multimídia e ambientes virtuais de aprendizagem, ampliando as possibilidades didáticas e favorecendo a participação dos estudantes no processo educativo.
                </p>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    
                </div>
            </section>

            <section>
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                        <i class="fas fa-users-gear text-blue-700"></i>
                    </div>
                    <h2 class="text-2xl font-heading font-bold text-slate-800">Equipe técnica</h2>
                </div>
                <div class="mb-6 rounded-2xl overflow-hidden shadow-sm border border-slate-100">
                    <img src="/img/NTM/equipe_tecnica.jpg" alt="Equipe Pedagógica" class="w-full max-h-[480px] object-cover object-center">
                </div>
                <p class="text-slate-600 leading-relaxed text-base mb-8 text-justify">
                        A equipe técnica é composta por 3 técnicos e 3 estagiários: Carlos Eduardo, Enilton, Daniel Cajarana, Estilren Lacerda, Marcos Vinícius e Eliezer. O setor de Tecnologia da Informação das escolas do município de Mossoró desempenha um papel essencial no suporte e no funcionamento do ambiente tecnológico educacional. A equipe é responsável pela manutenção de hardware e software, garantindo que computadores, sistemas e equipamentos estejam sempre operando com eficiência. Além disso, realiza a gestão e o monitoramento das redes, assegurando conectividade estável e segura para atividades administrativas e pedagógicas. Com atuação preventiva e corretiva, o setor busca minimizar falhas e otimizar o uso dos recursos tecnológicos. Esse trabalho contribui diretamente para o bom andamento das atividades escolares. A presença de uma equipe técnica qualificada fortalece a infraestrutura digital das unidades de ensino. Assim, a tecnologia se torna uma aliada no desenvolvimento da educação municipal.
                </p>
            </section>

            <section class="mb-10">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-user-tie text-blue-700"></i>
                        </div>
                        <h2 class="text-2xl font-heading font-bold text-slate-800">Diretor do NTM</h2>
                    </div>
                    <div class="flex gap-4">
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Frank.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Frank Werlly</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-chalkboard-user text-blue-700"></i>
                        </div>
                        <h2 class="text-2xl font-heading font-bold text-slate-800">Equipe Pedagógica</h2>
                    </div>
                    <div class="flex gap-4">
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/socorro.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Socorro Souza</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Cristhiane.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Cristhiane Marques</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Stenio.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Stênio Lucio</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-screwdriver-wrench text-blue-700"></i>
                        </div>
                        <h2 class="text-2xl font-heading font-bold text-slate-800">Equipe Técnica</h2>
                    </div>
                    <div class="flex gap-4">
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Lacerda.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Estilren Lacerda</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Enilton.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Enilton</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Eliezer.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Eliezer</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-user-graduate text-blue-700"></i>
                        </div>
                        <h2 class="text-2xl font-heading font-bold text-slate-800">Estagiários</h2>
                    </div>
                    <div class="flex gap-4">
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Carlos.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Carlos Eduardo</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Marcos.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Marcos Vinícius</p>
                        </div>
                        <div class="avatar flex flex-col items-center">
                            <div class="w-32 h-32 rounded overflow-hidden">
                                <img src="/img/NTM/Daniel.jpg" class="w-full h-full object-cover" />
                            </div>
                            <p class="text-center">Daniel Cajarana</p>
                        </div>
                    </div>
                </div>
            </section>

        </main>

        <%- include("../../componentes/pagina-inicial/footer") %>
    </div>
    <script src="/scripts/pagina-inicial/scripts.js"></script>
</body>

</html>
